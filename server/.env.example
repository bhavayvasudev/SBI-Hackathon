# ── Google Gemini API ──────────────────────────────────────────────────────────
# Required. Create at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# ── MongoDB ────────────────────────────────────────────────────────────────────
# Required. MongoDB Atlas connection string (or local: mongodb://localhost:27017/hyperone)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=HyperOne

# ── JWT ────────────────────────────────────────────────────────────────────────
# Required. Generate a strong secret: openssl rand -base64 48
JWT_SECRET=replace-with-64-char-random-secret

# ── Token Encryption (OAuth) ───────────────────────────────────────────────────
# Required when integrating OAuth providers (Google, Spotify, Plaid, etc.).
# Used by server/src/utils/tokenEncryption.js for AES-256-GCM.
# Generate: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=replace-with-strong-random-key

# ── Admin Credentials ─────────────────────────────────────────────────────────
# Required. Use strong, unique values — never commit the real values.
ADMIN_USERNAME=change-me
ADMIN_PASSWORD=change-me-to-a-strong-password

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── CORS ──────────────────────────────────────────────────────────────────────
CLIENT_URL=http://localhost:5173

# ── OAuth Providers (add only the ones you integrate) ─────────────────────────
# Google OAuth
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Spotify OAuth
# SPOTIFY_CLIENT_ID=
# SPOTIFY_CLIENT_SECRET=

# Plaid
# PLAID_CLIENT_ID=
# PLAID_SECRET=
# PLAID_ENV=sandbox
